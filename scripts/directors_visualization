import pandas as pd
import matplotlib.pyplot as plt
import seaborn as sns

print("--- Visualization script started ---")

# 1. Load the extended dataset
input_path = "data/processed/final_data_with_directors.csv"
try:
    df = pd.read_csv(input_path)
    print(f"Successfully loaded dataset from '{input_path}'.")
except Exception as e:
    print(f"Error loading file: {e}")
    import sys
    sys.exit(1)

# 2. Data Cleaning for cleaner visualizations
# Clean the character labels (remove sources like [14] and take the primary label before the semicolon)
df['Clean_Label'] = df['Final_Label'].fillna('Unknown').apply(
    lambda x: x.split(';')[0].split('[')[0].strip()
)

# Standardize director genders from gender-guesser output
df['Clean_Director_Gender'] = df['Director_Gender'].replace({
    'mostly_male': 'male',
    'mostly_female': 'female',
    'andy': 'unknown',
    'unknown': 'unknown'
})

# Filter out 'Not Found', 'Error', or 'Unknown' for a dedicated bias analysis
analysis_df = df[df['Clean_Director_Gender'].isin(['male', 'female'])]

# Set the visual style
sns.set_theme(style="whitegrid")

# --- Plot 1: Overall Distribution of Director Genders (Sorted) ---
fig, ax = plt.subplots(figsize=(8, 5))
gender_counts = analysis_df['Clean_Director_Gender'].value_counts()

sns.barplot(
    x=gender_counts.index, 
    y=gender_counts.values, 
    ax=ax, 
    palette='viridis', 
    order=gender_counts.index
)

ax.set_title("Distribution of Director Genders for LGBTQ+ Characters", fontsize=14, pad=15)
ax.set_xlabel("Director Gender", fontsize=12)
ax.set_ylabel("Number of Characters", fontsize=12)
plt.tight_layout()
plt.savefig("data/processed/director_gender_distribution.png")
plt.close()
print("Saved: 'data/processed/director_gender_distribution.png'")

# --- Plot 2: Gender Bias Analysis (Director Gender vs. Character Label, Sorted) ---
fig, ax = plt.subplots(figsize=(12, 6))
label_order = analysis_df['Clean_Label'].value_counts().index

sns.countplot(
    data=analysis_df, 
    x='Clean_Label', 
    hue='Clean_Director_Gender', 
    ax=ax, 
    palette='Set2',
    order=label_order
)

ax.set_title("LGBTQ+ Character Representation by Director Gender", fontsize=14, pad=15)
ax.set_xlabel("Character Identity Label", fontsize=12)
ax.set_ylabel("Count of Characters", fontsize=12)
ax.legend(title="Director Gender")
plt.xticks(rotation=45, ha='right')
plt.tight_layout()
plt.savefig("data/processed/gender_bias_representation.png")
plt.close()
print("Saved: 'data/processed/gender_bias_representation.png'")

print("\n--- Visualizations generated successfully! ---")